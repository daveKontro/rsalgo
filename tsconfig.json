{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": [
      "@types/chai",
      "@types/dotenv-flow",
      "@types/mocha",
      "@types/node"
    ],
  },
  "include": ["src"]
}
